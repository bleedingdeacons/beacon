{
    "name": "call-forwarding/beacon",
    "description": "Abstract interface plugin for call-forwarding systems. Defines contracts; an implementation plugin provides the concrete driver.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Your Organisation"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.1",
        "psr/container": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "10up/wp_mock": "^0.4.2",
        "mockery/mockery": "^1.4",
        "phpstan/phpstan": "^1.4",
        "szepeviktor/phpstan-wordpress": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Beacon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beacon\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "stan": "phpstan analyse -l 5 ./src",
        "analyse": "phpstan analyse src/"
    }
}
